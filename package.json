{
  "name": "live-architecture-map",
  "displayName": "Live Architecture Map",
  "description": "Visual architecture and change-impact dashboard for Python workspaces.",
  "version": "0.0.1",
  "publisher": "local-tools",
  "categories": [
    "Visualization",
    "Other"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onView:liveArchitectureMap.sidebar",
    "onCommand:liveArchitectureMap.openDashboard",
    "onCommand:liveArchitectureMap.refresh",
    "onCommand:liveArchitectureMap.captureBaseline",
    "onCommand:liveArchitectureMap.showDiffSinceBaseline",
    "workspaceContains:**/*.py"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "liveArchitectureMap",
          "title": "Live Architecture Map",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "liveArchitectureMap": [
        {
          "id": "liveArchitectureMap.sidebar",
          "name": "Architecture Map",
          "icon": "media/codicon-map.svg",
          "contextualTitle": "Live Architecture Map"
        }
      ]
    },
    "commands": [
      {
        "command": "liveArchitectureMap.openDashboard",
        "title": "Open Dashboard",
        "category": "Live Architecture Map",
        "icon": "$(graph)"
      },
      {
        "command": "liveArchitectureMap.refresh",
        "title": "Refresh",
        "category": "Live Architecture Map",
        "icon": "$(refresh)"
      },
      {
        "command": "liveArchitectureMap.captureBaseline",
        "title": "Capture Baseline",
        "category": "Live Architecture Map",
        "icon": "$(database)"
      },
      {
        "command": "liveArchitectureMap.showDiffSinceBaseline",
        "title": "Show Diff Since Baseline",
        "category": "Live Architecture Map",
        "icon": "$(compare-changes)"
      },
      {
        "command": "liveArchitectureMap.focusFeature",
        "title": "Focus Feature",
        "category": "Live Architecture Map",
        "icon": "$(target)"
      },
      {
        "command": "liveArchitectureMap.exportSnapshot",
        "title": "Export Snapshot",
        "category": "Live Architecture Map",
        "icon": "$(export)"
      },
      {
        "command": "liveArchitectureMap.clearWorkspaceCache",
        "title": "Clear Workspace Cache",
        "category": "Live Architecture Map",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "liveArchitectureMap.openDashboard",
          "when": "view == liveArchitectureMap.sidebar",
          "group": "navigation"
        },
        {
          "command": "liveArchitectureMap.refresh",
          "when": "view == liveArchitectureMap.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Live Architecture Map",
      "properties": {
        "liveArchitectureMap.autoWatch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically watch workspace changes after activation."
        },
        "liveArchitectureMap.autoOpenDashboard": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the dashboard when the extension activates."
        },
        "liveArchitectureMap.defaultModeWhenClean": {
          "type": "string",
          "enum": [
            "wholeArchitecture",
            "liveChanges"
          ],
          "default": "wholeArchitecture",
          "description": "Dashboard mode to show when there are no modified files."
        },
        "liveArchitectureMap.defaultModeWhenDirty": {
          "type": "string",
          "enum": [
            "liveChanges",
            "wholeArchitecture"
          ],
          "default": "liveChanges",
          "description": "Dashboard mode to show when modified files are detected."
        },
        "liveArchitectureMap.maxFilesToAnalyze": {
          "type": "number",
          "default": 2000,
          "description": "Maximum number of workspace files to analyze for architecture graph generation."
        },
        "liveArchitectureMap.excludeGlobs": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/.venv/**",
            "**/venv/**",
            "**/__pycache__/**",
            "**/node_modules/**",
            "**/build/**",
            "**/install/**",
            "**/log/**",
            "**/.pytest_cache/**"
          ],
          "description": "Glob patterns excluded from architecture analysis."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && tsc -p ./tsconfig.test.json && node ./out-test/test/suite/extension.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.0"
  }
}
