{
  "name": "live-architecture-map",
  "displayName": "Live Architecture Map",
  "description": "Visual architecture and change-impact dashboard for Python workspaces.",
  "version": "0.0.1",
  "publisher": "local-tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/June-Jevons/vs_extension_work.git"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "engines": {
    "vscode": "^1.119.0",
    "node": ">=20",
    "npm": ">=10"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onView:liveArchitectureMap.launcher",
    "onCommand:liveArchitectureMap.openDashboard",
    "onCommand:liveArchitectureMap.refresh",
    "onCommand:liveArchitectureMap.captureBaseline",
    "onCommand:liveArchitectureMap.showDiffSinceBaseline",
    "onCommand:liveArchitectureMap.focusFeature",
    "onCommand:liveArchitectureMap.exportSnapshot",
    "onCommand:liveArchitectureMap.configure",
    "onCommand:liveArchitectureMap.focusTimeline",
    "onCommand:liveArchitectureMap.clearWorkspaceCache",
    "workspaceContains:**/*.py"
  ],
  "contributes": {
    "commands": [
      {
        "command": "liveArchitectureMap.openDashboard",
        "title": "Live Architecture Map: Open Dashboard"
      },
      {
        "command": "liveArchitectureMap.refresh",
        "title": "Live Architecture Map: Refresh"
      },
      {
        "command": "liveArchitectureMap.captureBaseline",
        "title": "Live Architecture Map: Capture Baseline"
      },
      {
        "command": "liveArchitectureMap.showDiffSinceBaseline",
        "title": "Live Architecture Map: Show Diff Since Baseline"
      },
      {
        "command": "liveArchitectureMap.focusFeature",
        "title": "Live Architecture Map: Focus Feature"
      },
      {
        "command": "liveArchitectureMap.exportSnapshot",
        "title": "Live Architecture Map: Export Snapshot"
      },
      {
        "command": "liveArchitectureMap.configure",
        "title": "Live Architecture Map: Configure"
      },
      {
        "command": "liveArchitectureMap.focusTimeline",
        "title": "Live Architecture Map: Focus Timeline"
      },
      {
        "command": "liveArchitectureMap.clearWorkspaceCache",
        "title": "Live Architecture Map: Clear Workspace Cache"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "liveArchitectureMap",
          "title": "Live Architecture Map",
          "icon": "media/codicon-map.svg"
        }
      ]
    },
    "views": {
      "liveArchitectureMap": [
        {
          "id": "liveArchitectureMap.launcher",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Live Architecture Map",
      "properties": {
        "liveArchitectureMap.autoWatch": {
          "type": "boolean",
          "default": true,
          "description": "Watch workspace changes and refresh the architecture map."
        },
        "liveArchitectureMap.autoOpenDashboard": {
          "type": "boolean",
          "default": false,
          "description": "Open the dashboard automatically when the extension activates."
        },
        "liveArchitectureMap.defaultModeWhenClean": {
          "type": "string",
          "enum": [
            "wholeArchitecture",
            "liveChanges"
          ],
          "default": "wholeArchitecture",
          "description": "Dashboard mode to use when the workspace has no detected changes."
        },
        "liveArchitectureMap.defaultModeWhenDirty": {
          "type": "string",
          "enum": [
            "liveChanges",
            "wholeArchitecture"
          ],
          "default": "liveChanges",
          "description": "Dashboard mode to use when the workspace has detected changes."
        },
        "liveArchitectureMap.maxFilesToAnalyze": {
          "type": "number",
          "default": 2000,
          "description": "Maximum number of files to analyze in later scanner phases."
        },
        "liveArchitectureMap.excludeGlobs": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/.venv/**",
            "**/venv/**",
            "**/__pycache__/**",
            "**/node_modules/**",
            "**/out/**",
            "**/out-test/**",
            "**/out-scripts/**",
            "**/artifacts/**",
            "**/.vscode-test/**",
            "**/test-results/**",
            "**/playwright-report/**",
            "**/coverage/**",
            "**/build/**",
            "**/install/**",
            "**/log/**",
            "**/.pytest_cache/**"
          ],
          "description": "Globs excluded from later scanner phases."
        }
      }
    }
  },
  "scripts": {
    "clean:compiled": "rm -rf out out-test out-scripts",
    "compile:extension": "tsc -p ./",
    "compile:webview": "tsc -p ./tsconfig.webview.json && vite build --config ./webview.vite.config.ts",
    "compile": "npm run clean:compiled && npm run compile:extension && npm run compile:webview",
    "watch:extension": "tsc -watch -p ./",
    "watch:webview": "vite build --watch --config ./webview.vite.config.ts",
    "watch": "npm run watch:extension",
    "test": "npm run compile && npm run test:unit",
    "test:unit": "tsc -p ./tsconfig.test.json && node ./out-test/test/suite/runTests.js",
    "visual:render": "npm run compile && tsc -p ./tsconfig.scripts.json && node ./out-scripts/scripts/render-ui-snapshots.js",
    "visual:test": "playwright test",
    "test:vscode": "npm run compile && tsc -p ./tsconfig.test.json && vscode-test --config ./.vscode-test.mjs",
    "test:vscode:headless": "xvfb-run -a npm run test:vscode",
    "doctor:ubuntu": "tsc -p ./tsconfig.scripts.json && node ./out-scripts/scripts/doctor-ubuntu.js",
    "validate": "npm run compile && npm run test:unit && npm run visual:render && npm run visual:test",
    "validate:full": "npm run doctor:ubuntu && npm run validate && npm run test:vscode && npm run package && npm run verify:vsix",
    "package": "npm run compile && vsce package",
    "verify:vsix": "tsc -p ./tsconfig.scripts.json && node ./out-scripts/scripts/verify-vsix-contents.js"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.118.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.1",
    "typescript": "6.0.3",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
